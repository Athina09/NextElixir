# ─── ForecastIQ environment configuration ────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env — it's
# gitignored at the repo root (see .gitignore) and inside backend/.

# ── LLM (AI insights & chat) — never used for prediction ───────────────────
# Obtain a key from https://aistudio.google.com/app/apikey
# Missing this is not fatal: run.sh and /forecast work without it; only
# /insights and /chat return 503 until it's set.
GEMINI_API_KEY=

# Gemini model used for AI narration/chat.
GEMINI_MODEL=gemini-2.5-flash

# ── Database (dashboard history/users/reports/chat only — run.sh never
# touches this) ──────────────────────────────────────────────────────────────
# Docker Compose default:
DATABASE_URL=postgresql+psycopg2://forecastiq:forecastiq@localhost:5432/forecastiq
# Zero-setup local dev alternative (SQLite, no Postgres required):
# DATABASE_URL=sqlite:///./forecastiq_dev.db

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── CORS (allowed origins for the frontend) ──────────────────────────────────
# JSON array. Add your production frontend URL when deploying.
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# ── Frontend (TanStack Start / Vite) ─────────────────────────────────────────
# URL of the running backend. Defaults to http://localhost:8000 if unset.
VITE_API_URL=http://localhost:8000

# ── Postgres (docker-compose only) ───────────────────────────────────────────
POSTGRES_USER=forecastiq
POSTGRES_PASSWORD=forecastiq
POSTGRES_DB=forecastiq
