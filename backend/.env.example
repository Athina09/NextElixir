# Copy to .env and fill in real values. Never commit .env (see .gitignore).
# Not required for run.sh / the hackathon submission path — only for the
# live FastAPI dashboard (train.py and run.sh work with zero env vars set).

# LLM (AI insights & chat only — never used for prediction).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Dashboard history/users/reports/chat storage only.
DATABASE_URL=postgresql+psycopg2://forecastiq:forecastiq@localhost:5432/forecastiq

ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
